---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('about', 'index');
if (!entry) {
  throw new Error('Missing required content entry: about/index');
}
const { Content } = await render(entry);
const { data } = entry;
---

<BaseLayout title="About — Alexandre Galatioto">
  <div class="about-layout">
    <div class="about-portrait">
      <Image
        src={data.portrait}
        alt="Alexandre Galatioto"
        widths={[640, 960, 1280]}
        sizes="(max-width: 640px) 100vw, 50vw"
        format="webp"
        loading="eager"
      />
    </div>
    <div class="about-content">
      <div class="about-titles">
        {data.pageTitles.map((title) => (
          <h1 class="about-title">{title}</h1>
        ))}
      </div>
      <div class="about-bio">
        <Content />
      </div>
      <div class="about-contact">
        {data.email && (
          <div class="about-contact__col">
            <h2>E-mail</h2>
            <p>{data.email}</p>
          </div>
        )}
        <div class="about-contact__col">
          <h2>Socials</h2>
          <ul>
            {data.linkedinUrl && (
              <li><a href={data.linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
            )}
            {data.instagramUrl && (
              <li><a href={data.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a></li>
            )}
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(30px, 5vw, 100px);
    padding-left: 50px;
    padding-right: 100px;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-2xl);
  }

  .about-portrait img {
    width: 100%;
    height: auto;
    display: block;
  }

  .about-bio {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-body);
  }

  .about-titles {
    margin-top: 50px;
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .about-title {
    font-size: 38px;
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    line-height: var(--line-height-heading);
  }

  .about-contact {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .about-contact h2 {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: 4px;
  }

  .about-contact p,
  .about-contact a {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text);
    line-height: 1.2;
  }

  .about-contact p {
    text-decoration: none;
  }

  .about-contact a {
    text-decoration: underline;
  }

  .about-contact ul {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  @media (max-width: 800px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .about-portrait {
      margin-left: calc(-1 * 50px);
      margin-right: calc(-1 * 100px);
      height: 350px;
      overflow: hidden;
    }

    .about-titles {
      margin-top: 0;
    }

    .about-contact {
      grid-template-columns: 1fr;
    }
  }
</style>
