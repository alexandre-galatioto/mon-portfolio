---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Work — Alexandre Galatioto">
  <ul class="project-grid">
    {sorted.map((project, i) => (
      <li class="project-cell">
        <a href={`/projects/${project.slug}`}>
          <Image
            src={project.data.images[0]}
            alt={project.data.title}
            widths={[640, 960, 1280, 1600]}
            sizes="(max-width: 640px) 100vw, 50vw"
            format="webp"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          <span class="project-overlay">{project.data.type}</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 11px;
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .project-cell a {
    display: block;
    position: relative;
  }

  .project-cell img {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    text-transform: none;
    background: rgba(255, 255, 255, 0);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.25, 0.1, 0.25, 1.0), background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1.0);
    pointer-events: none;
  }

  .project-cell a:hover .project-overlay {
    opacity: 1;
    background: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: 1fr;
      padding-top: 50px;
      padding-bottom: 50px;
    }
  }

  @media (max-width: 640px) {
    .project-grid {
      padding-top: 30px;
      padding-bottom: 30px;
    }
  }
</style>
