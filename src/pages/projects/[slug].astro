---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<BaseLayout title={`${data.title} — Alexandre Galatioto`} description={data.description} navWhite={data.navWhite}>
  <div class="project-cover">
    <Image
      src={data.images[0]}
      alt={data.title}
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      format="webp"
      loading="eager"
    />
  </div>

  <section class="project-meta">
    <div class="project-meta__left">
      <h1>{data.title}</h1>
      <p class="project-type">{data.type}</p>
    </div>
    <div class="project-meta__right">
      <p>{data.description}</p>
      {data.liveUrl && (
        <a
          href={data.liveUrl}
          class="project-demo-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${data.title} project (opens in new tab)`}
        >
          View project
        </a>
      )}
    </div>
  </section>

  <div class="project-gallery">
    {data.images.slice(1).map((img) => (
      <Image
        src={img}
        alt=""
        widths={[640, 960, 1280, 1600]}
        sizes="(max-width: 640px) calc(100vw - 32px), min(calc(100vw - 64px), 1280px)"
        format="webp"
        loading="lazy"
      />
    ))}
  </div>

  <div class="project-body">
    <Content />
  </div>

  <nav class="project-nav" aria-label="Project navigation">
    {prev && (
      <a href={`/projects/${prev.slug}`} class="project-nav__prev">
        <span class="sr-only">Previous project: </span>{prev.data.title}
      </a>
    )}
    {next && (
      <a href={`/projects/${next.slug}`} class="project-nav__next">
        <span class="sr-only">Next project: </span>{next.data.title}
      </a>
    )}
  </nav>
</BaseLayout>

<style>
  :global(body) {
    padding-top: 0;
    --_padding-top: 0px;
  }

  :global(.site-nav) {
    position: absolute;
    top: 50px;
    left: 100px;
    right: 100px;
    z-index: 100;
  }

  @media (max-width: 1024px) {
    :global(.site-nav) {
      left: 50px;
      right: 50px;
    }
  }

  @media (max-width: 640px) {
    :global(.site-nav) {
      left: 30px;
      right: 30px;
    }
  }


  .project-cover {
    width: 100vw;
    margin-left: calc(-1 * var(--_padding-inline));
  }

  .project-cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: top;
  }

  @media (min-width: 1124px) {
    .project-cover {
      aspect-ratio: 1800 / 800;
      overflow: hidden;
    }
  }

  @media (max-width: 1123px) {
    .project-cover {
      height: 650px;
      overflow: hidden;
    }
  }

  .project-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    padding-block: var(--space-2xl);
  }

  .project-meta h1 {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
  }

  .project-type {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  .project-meta__right p {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-body);
  }

  .project-demo-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text);
    text-decoration: none;
  }

  .project-demo-link:hover {
    text-decoration: underline;
  }

  .project-gallery {
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin-top: var(--space-lg);
  }

  .project-gallery img {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-nav {
    display: flex;
    justify-content: space-between;
    padding-block: var(--space-2xl);
  }

  .project-nav a {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text);
    text-decoration: none;
  }

  .project-nav a:hover {
    text-decoration: underline;
  }

  .project-nav__next {
    margin-left: auto;
  }

  @media (max-width: 640px) {
    .project-meta {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const cover = document.querySelector('.project-cover') as HTMLElement | null;
  const img = cover?.querySelector('img') as HTMLElement | null;

  if (cover && img && window.matchMedia('(min-width: 769px)').matches) {
    const speed = 0.3;

    function getMaxOffset() {
      const containerW = cover!.clientWidth;
      const containerH = cover!.clientHeight;
      const naturalW = (img as HTMLImageElement).naturalWidth;
      const naturalH = (img as HTMLImageElement).naturalHeight;
      const scale = Math.max(containerW / naturalW, containerH / naturalH);
      return Math.max(0, naturalH * scale - containerH);
    }

    function onScroll() {
      const offset = Math.min(window.scrollY * speed, getMaxOffset());
      img!.style.objectPosition = `center ${-offset}px`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
